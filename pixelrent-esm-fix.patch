+
+export const dynamic = "force-dynamic";
+export const runtime = "nodejs";
 
 const VAT_RATE = 0.12; // Philippine VAT
 const SHIPPING_FEE = 0;
 
-/** POST /api/checkout — SIMULATED payment. Validates the cart,
