-    subtotal,
-    shipping: SHIPPING_FEE,
-    vat,
-    total,
-    paymentMethod: body.paymentMethod,
-    placedAt: new Date().toISOString(),
-    simulated: true as const,
-  };
-  store.orders.push(order);
-
-  return NextResponse.json({ order });
 }
